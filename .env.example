DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me

DB_ENGINE=django.db.backends.postgresql
DB_DATABASE=py_crud
DB_USERNAME=postgres
DB_PASSWORD=root
DB_HOST=localhost
DB_PORT=5432

# Email (dev default prints to the console; switch to SMTP for real delivery)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=webmaster@localhost

# Celery (scaffolded, not started anywhere yet — needs a running Redis to matter)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Firebase (not wired up yet — see apps/notifications/services.py)
FIREBASE_CREDENTIALS_PATH=
